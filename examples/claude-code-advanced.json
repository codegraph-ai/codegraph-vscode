{
  "_comment": "Advanced — using the binary directly (requires --mcp flag)",
  "_embedding_models": "jina-code-v2 (best quality, 768d) or bge-small (5x faster, 384d)",
  "mcpServers": {
    "codegraph": {
      "command": "/path/to/codegraph-lsp",
      "args": [
        "--mcp",
        "--workspace", "/path/to/your/project",
        "--workspace", "/path/to/another/project",
        "--exclude", "cmake-build-debug",
        "--exclude", "generated",
        "--embedding-model", "jina-code-v2",
        "--max-files", "5000"
      ]
    }
  }
}
